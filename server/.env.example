# Local dev: point both at the same Postgres.
# Production (Supabase): DATABASE_URL = transaction pooler (port 6543, ?pgbouncer=true),
#                        DIRECT_URL   = direct connection (port 5432) for migrations.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cashtrail?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/cashtrail?schema=public"
JWT_SECRET="change-me"
PORT=4000
# From Google Cloud Console > Credentials > OAuth 2.0 Client ID (Web application)
GOOGLE_CLIENT_ID=""
