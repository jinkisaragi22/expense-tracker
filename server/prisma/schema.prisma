generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TxType {
  income
  expense
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  passwordHash String?       @map("password_hash")
  googleId     String?       @unique @map("google_id")
  createdAt    DateTime      @default(now()) @map("created_at")
  categories      Category[]
  transactions    Transaction[]
  monthlyBalances MonthlyBalance[]
  splitBills      SplitBill[]

  @@map("users")
}

model SplitBill {
  id           String             @id @default(uuid())
  userId       String             @map("user_id")
  title        String
  note         String             @default("")
  total        Decimal            @db.Decimal(14, 2)
  shareToken   String             @unique @default(uuid()) @map("share_token")
  createdAt    DateTime           @default(now()) @map("created_at")
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  participants SplitParticipant[]

  @@map("split_bills")
}

model SplitParticipant {
  id          String    @id @default(uuid())
  splitBillId String    @map("split_bill_id")
  name        String
  amount      Decimal   @db.Decimal(14, 2)
  paid        Boolean   @default(false)
  splitBill   SplitBill @relation(fields: [splitBillId], references: [id], onDelete: Cascade)

  @@map("split_participants")
}

model MonthlyBalance {
  id     String  @id @default(uuid())
  userId String  @map("user_id")
  month  String
  amount Decimal @db.Decimal(14, 2)
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@map("monthly_balances")
}

model Category {
  id           String        @id @default(uuid())
  userId       String?       @map("user_id")
  name         String
  type         TxType
  icon         String        @default("💰")
  color        String        @default("#6366f1")
  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("categories")
}

model Transaction {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  categoryId  String   @map("category_id")
  amount      Decimal  @db.Decimal(14, 2)
  type        TxType
  description String   @default("")
  date        DateTime @db.Date
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([userId, date])
  @@map("transactions")
}
